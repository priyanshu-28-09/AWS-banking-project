# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Tables
DYNAMODB_USERS_TABLE=CloudBank_Users
DYNAMODB_ACCOUNTS_TABLE=CloudBank_Accounts
DYNAMODB_TRANSACTIONS_TABLE=CloudBank_Transactions

# SNS Topics
SNS_TRANSACTION_ALERTS_ARN=arn:aws:sns:us-east-1:account-id:TransactionAlerts
SNS_COMPLIANCE_ALERTS_ARN=arn:aws:sns:us-east-1:account-id:ComplianceAlerts
SNS_SYSTEM_ALERTS_ARN=arn:aws:sns:us-east-1:account-id:SystemAlerts

# Flask Configuration
FLASK_SECRET_KEY=your_secret_key_here_change_in_production
FLASK_ENV=development
DEBUG=True

# Security
SESSION_TIMEOUT=1800
BCRYPT_ROUNDS=12

# Fraud Detection Thresholds
FRAUD_ALERT_THRESHOLD=70
FRAUD_FREEZE_THRESHOLD=90
