# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local Storage Mode (set to True to use local JSON storage instead of AWS DynamoDB)
USE_LOCAL_STORAGE=True

# DynamoDB Tables
DYNAMODB_USERS_TABLE=CloudBank_Users
DYNAMODB_ACCOUNTS_TABLE=CloudBank_Accounts
DYNAMODB_TRANSACTIONS_TABLE=CloudBank_Transactions

# SNS Topics
SNS_TRANSACTION_ALERTS_ARN=
SNS_COMPLIANCE_ALERTS_ARN=
SNS_SYSTEM_ALERTS_ARN=

# Flask Configuration
FLASK_SECRET_KEY=dev-secret-key-for-local-testing-change-in-production
FLASK_ENV=development
DEBUG=True

# Security
SESSION_TIMEOUT=1800
BCRYPT_ROUNDS=12

# Fraud Detection
FRAUD_ALERT_THRESHOLD=70
FRAUD_FREEZE_THRESHOLD=90
